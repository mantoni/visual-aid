{
  "name": "visual-aid",
  "version": "0.1.0",
  "private": true,
  "description": "A Tauri visual aid that coding agents can launch and send structured data to over MCP.",
  "type": "module",
  "scripts": {
    "start": "tsx scripts/start.ts",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "demo:payload": "tsx scripts/demo-payload.ts",
    "mcp": "tsx mcp/server.ts",
    "release:plan": "tsx scripts/release.ts --json",
    "test": "vitest run",
    "verify": "npm run check && npm run test && npm run build",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "keywords": [
    "tauri",
    "mcp",
    "visualization",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "*",
    "@tauri-apps/api": "^2.10.1",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.13.0",
    "zod": "*"
  },
  "devDependencies": {
    "@tauri-apps/cli": "*",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "*",
    "jsdom": "^28.1.0",
    "tsx": "*",
    "typescript": "*",
    "vite": "*",
    "vitest": "^4.1.0"
  }
}
